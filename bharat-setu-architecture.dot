digraph BharatSetuArchitecture {
    // Graph settings
    rankdir=TB;
    compound=true;
    node [shape=box, style=filled, fontname="Arial"];
    edge [fontname="Arial", fontsize=10];
    
    // Color scheme
    bgcolor="#f5f5f5";
    
    // Client Layer
    subgraph cluster_client {
        label="CLIENT LAYER";
        style=filled;
        color="#e3f2fd";
        fontsize=14;
        fontname="Arial Bold";
        
        farmer [label="Farmer/VLE\nUsers", shape=ellipse, fillcolor="#90caf9"];
        officials [label="Sarpanch/\nDistrict Officials", shape=ellipse, fillcolor="#90caf9"];
        mobile [label="Flutter Mobile App\nPush-to-Talk + Vosk", fillcolor="#64b5f6"];
        web [label="React.js Dashboard\nCrisis Map + Traffic Light", fillcolor="#64b5f6"];
        
        farmer -> mobile;
        officials -> web;
    }
    
    // API Layer
    subgraph cluster_api {
        label="API LAYER";
        style=filled;
        color="#fff3e0";
        fontsize=14;
        fontname="Arial Bold";
        
        apigw [label="AWS API Gateway\nREST + WebSocket", fillcolor="#ffb74d"];
        cognito [label="AWS Cognito\nJWT Auth + RBAC", fillcolor="#ffb74d"];
        
        apigw -> cognito;
    }
    
    // Orchestration Layer
    subgraph cluster_orchestration {
        label="ORCHESTRATION LAYER";
        style=filled;
        color="#f3e5f5";
        fontsize=14;
        fontname="Arial Bold";
        
        bedrock [label="Amazon Bedrock\nClaude 3 Haiku\nIntent Extraction", fillcolor="#ce93d8"];
        eventbridge [label="Amazon EventBridge\nEvent Router", fillcolor="#ce93d8"];
        
        bedrock -> eventbridge;
    }
    
    // Service Layer - Carbon-Kosh
    subgraph cluster_carbon {
        label="CARBON-KOSH (70%)";
        style=filled;
        color="#e8f5e9";
        fontsize=12;
        fontname="Arial Bold";
        
        voice_lambda [label="Voice Processing\nLambda", fillcolor="#81c784"];
        satellite_lambda [label="Satellite Acquisition\nLambda (Sentinel-1 SAR)", fillcolor="#81c784"];
        verification_lambda [label="Verification\nLambda (SageMaker)", fillcolor="#81c784"];
        traffic_lambda [label="Traffic Light\nVerifier Lambda", fillcolor="#81c784"];
        escrow_lambda [label="Escrow & Settlement\nEngine Lambda", fillcolor="#81c784"];
    }
    
    // Service Layer - Gram-Twin
    subgraph cluster_gram {
        label="GRAM-TWIN (15%)";
        style=filled;
        color="#fff9c4";
        fontsize=12;
        fontname="Arial Bold";
        
        twin_lambda [label="Digital Twin\nLambda", fillcolor="#fff176"];
        hotspot_lambda [label="Hotspot Detection\nLambda", fillcolor="#fff176"];
    }
    
    // Service Layer - Migration-Shield
    subgraph cluster_migration {
        label="MIGRATION-SHIELD (15%)";
        style=filled;
        color="#ffebee";
        fontsize=12;
        fontname="Arial Bold";
        
        threshold_lambda [label="Threshold Monitor\nLambda", fillcolor="#ef5350"];
        alert_lambda [label="Alert Notification\nLambda (SNS/SES)", fillcolor="#ef5350"];
    }
    
    // Data Layer
    subgraph cluster_data {
        label="DATA LAYER";
        style=filled;
        color="#e0f2f1";
        fontsize=14;
        fontname="Arial Bold";
        
        s3 [label="AWS S3\nSatellite Imagery\nEvidence Vault", fillcolor="#4db6ac"];
        aurora [label="Aurora Serverless v2\nPostgreSQL + PostGIS\nGeospatial Data", fillcolor="#4db6ac"];
        sagemaker [label="Amazon SageMaker\nSentinel-1 SAR Model\nBiomass Analysis", fillcolor="#4db6ac"];
    }
    
    // External Integrations
    subgraph cluster_external {
        label="EXTERNAL INTEGRATIONS";
        style=filled;
        color="#fce4ec";
        fontsize=14;
        fontname="Arial Bold";
        
        bhashini [label="Bhashini API\nCloud Fallback\n(10% of requests)", fillcolor="#f48fb1"];
        sentinel [label="Sentinel-1 SAR\nCopernicus Hub\nAll-Weather Data", fillcolor="#f48fb1"];
        mapmyindia [label="MapMyIndia\nCadastral Maps\nSurvey Numbers", fillcolor="#f48fb1"];
        erupi [label="e-RUPI Mock\nNPCI Voucher\n(Pilot Phase)", fillcolor="#f48fb1"];
    }
    
    // Connections - Client to API
    mobile -> apigw [label="HTTPS/TLS 1.3"];
    web -> apigw [label="HTTPS/TLS 1.3"];
    
    // Connections - API to Orchestration
    cognito -> bedrock [label="JWT Token"];
    
    // Connections - Orchestration to Services
    eventbridge -> voice_lambda [label="Voice Request Event"];
    eventbridge -> satellite_lambda [label="Farm Registration Event"];
    eventbridge -> verification_lambda [label="Satellite Data Ready"];
    eventbridge -> traffic_lambda [label="Verification Complete"];
    eventbridge -> escrow_lambda [label="Traffic Light Green"];
    eventbridge -> twin_lambda [label="Digital Twin Request"];
    eventbridge -> hotspot_lambda [label="Hotspot Analysis"];
    eventbridge -> threshold_lambda [label="Scheduled Check"];
    
    // Connections - Services to Data
    voice_lambda -> bhashini [label="Fallback\n(confidence < 80%)", style=dashed];
    satellite_lambda -> sentinel [label="Download Imagery"];
    satellite_lambda -> s3 [label="Store Tiles"];
    verification_lambda -> s3 [label="Read Tiles"];
    verification_lambda -> sagemaker [label="Biomass Inference"];
    verification_lambda -> aurora [label="Store Results"];
    traffic_lambda -> aurora [label="VLE Trust Score"];
    traffic_lambda -> sagemaker [label="Satellite Verification"];
    escrow_lambda -> erupi [label="Generate Voucher"];
    escrow_lambda -> aurora [label="Audit Trail"];
    twin_lambda -> aurora [label="Aggregate Data"];
    twin_lambda -> mapmyindia [label="Infrastructure Data"];
    hotspot_lambda -> aurora [label="NDVI History"];
    threshold_lambda -> aurora [label="Vital Signs"];
    alert_lambda -> web [label="WebSocket Alert"];
    
    // Legend
    subgraph cluster_legend {
        label="LEGEND";
        style=filled;
        color="#ffffff";
        fontsize=10;
        
        legend1 [label="Solid Line = Primary Flow", shape=plaintext];
        legend2 [label="Dashed Line = Fallback/Optional", shape=plaintext];
        legend3 [label="Cost: $1.70/village/month", shape=plaintext, fontcolor="#d32f2f"];
    }
}
