digraph BharatSetuArchitecture {
    // Graph settings
    rankdir=TB;
    compound=true;
    node [shape=box, style=filled, fontname="Arial"];
    edge [fontname="Arial", fontsize=10];
    
    // Color scheme
    bgcolor="#f5f5f5";
    
    // Client Layer
    subgraph cluster_client {
        label="CLIENT LAYER";
        style=filled;
        color="#e3f2fd";
        fontsize=14;
        fontname="Arial Bold";
        
        farmer [label="Farmer/VLE\nUsers", shape=ellipse, fillcolor="#90caf9"];
        officials [label="Sarpanch/\nDistrict Officials", shape=ellipse, fillcolor="#90caf9"];
        mobile [label="Flutter Mobile App\nPush-to-Talk + Vosk", fillcolor="#64b5f6"];
        web [label="React.js Dashboard\nCrisis Map + Traffic Light", fillcolor="#64b5f6"];
        
        farmer -> mobile;
        officials -> web;
    }
    
    // API Layer
    subgraph cluster_api {
        label="API LAYER";
        style=filled;
        color="#fff3e0";
        fontsize=14;
        fontname="Arial Bold";
        
        fastapi [label="FastAPI Application\nREST APIs + WebSockets", fillcolor="#ffb74d"];
        jwt_auth [label="PyJWT Authentication\nLocal RBAC", fillcolor="#ffb74d"];
        
        fastapi -> jwt_auth;
    }
    
    // Orchestration Layer
    subgraph cluster_orchestration {
        label="ORCHESTRATION LAYER";
        style=filled;
        color="#f3e5f5";
        fontsize=14;
        fontname="Arial Bold";
        
        voice_model [label="Local Extraction Model\nKeyword Intent\nProcessing", fillcolor="#ce93d8"];
        local_bus [label="In-Process EventBus\nAsync Pub/Sub Router", fillcolor="#ce93d8"];
        
        voice_model -> local_bus;
    }
    
    // Service Layer - Carbon-Kosh
    subgraph cluster_carbon {
        label="CARBON-KOSH (70%)";
        style=filled;
        color="#e8f5e9";
        fontsize=12;
        fontname="Arial Bold";
        
        voice_service [label="Voice Processing\nService", fillcolor="#81c784"];
        satellite_service [label="Satellite Acquisition\nService (Sentinel-1 SAR)", fillcolor="#81c784"];
        verification_service [label="Verification\nService (Local ML)", fillcolor="#81c784"];
        traffic_service [label="Traffic Light Protocol\nVariance Tracking", fillcolor="#81c784"];
        escrow_service [label="Escrow & Settlement\nEngine (Mock e-RUPI)", fillcolor="#81c784"];
    }
    
    // Service Layer - Gram-Twin
    subgraph cluster_gram {
        label="GRAM-TWIN (15%)";
        style=filled;
        color="#fff9c4";
        fontsize=12;
        fontname="Arial Bold";
        
        twin_service [label="Digital Twin\nAggregation Service", fillcolor="#fff176"];
        hotspot_service [label="Hotspot Detection\nService", fillcolor="#fff176"];
    }
    
    // Service Layer - Migration-Shield
    subgraph cluster_migration {
        label="MIGRATION-SHIELD (15%)";
        style=filled;
        color="#ffebee";
        fontsize=12;
        fontname="Arial Bold";
        
        threshold_service [label="Boolean Threshold\nMonitor Service", fillcolor="#ef5350"];
        alert_service [label="Alert Notification\nService", fillcolor="#ef5350"];
    }
    
    // Data Layer
    subgraph cluster_data {
        label="DATA LAYER (FRUGAL)";
        style=filled;
        color="#e0f2f1";
        fontsize=14;
        fontname="Arial Bold";
        
        local_storage [label="Local Filesystem\nSatellite Imagery\nEvidence Vault", fillcolor="#4db6ac"];
        sqlite_db [label="SQLite Database\nRelational Data\nJSON Geospatial", fillcolor="#4db6ac"];
        local_ml [label="Local ML Inference\nBiomass Analysis\nVariance Models", fillcolor="#4db6ac"];
    }
    
    // External Integrations
    subgraph cluster_external {
        label="EXTERNAL INTEGRATIONS";
        style=filled;
        color="#fce4ec";
        fontsize=14;
        fontname="Arial Bold";
        
        bhashini [label="Bhashini API\nCloud Fallback\n(10% of requests)", fillcolor="#f48fb1"];
        sentinel [label="Sentinel-1 SAR\nCopernicus Hub\nAll-Weather Data", fillcolor="#f48fb1"];
        mapmyindia [label="MapMyIndia\nCadastral Maps\nSurvey Numbers", fillcolor="#f48fb1"];
        erupi [label="e-RUPI Adapter\nNPCI Voucher\n(MOCK)", fillcolor="#f48fb1"];
    }
    
    // Connections - Client to API
    mobile -> fastapi [label="HTTPS/TLS 1.3"];
    web -> fastapi [label="HTTPS/TLS 1.3"];
    
    // Connections - API to Orchestration
    jwt_auth -> voice_model [label="Verified User Context"];
    
    // Connections - Orchestration to Services
    local_bus -> voice_service [label="Voice Request Event"];
    local_bus -> satellite_service [label="Farm Registration Event"];
    local_bus -> verification_service [label="Satellite Data Ready"];
    local_bus -> traffic_service [label="Verification Complete"];
    local_bus -> escrow_service [label="Traffic Light Green"];
    local_bus -> twin_service [label="Digital Twin Request"];
    local_bus -> hotspot_service [label="Hotspot Analysis"];
    local_bus -> threshold_service [label="Scheduled Check"];
    
    // Connections - Services to Data
    voice_service -> bhashini [label="Fallback\n(confidence < 80%)", style=dashed];
    satellite_service -> sentinel [label="Download Imagery"];
    satellite_service -> local_storage [label="Store Tiles"];
    verification_service -> local_storage [label="Read Tiles"];
    verification_service -> local_ml [label="Biomass Inference"];
    verification_service -> sqlite_db [label="Store Results"];
    traffic_service -> sqlite_db [label="VLE Trust Score"];
    traffic_service -> local_ml [label="Satellite Verification"];
    escrow_service -> erupi [label="Generate Voucher"];
    escrow_service -> sqlite_db [label="Audit Trail"];
    twin_service -> sqlite_db [label="Aggregate Data"];
    twin_service -> mapmyindia [label="Infrastructure Data"];
    hotspot_service -> sqlite_db [label="NDVI History"];
    threshold_service -> sqlite_db [label="Vital Signs"];
    alert_service -> web [label="WebSocket Alert"];
    
    // Legend
    subgraph cluster_legend {
        label="LEGEND";
        style=filled;
        color="#ffffff";
        fontsize=10;
        
        legend1 [label="Solid Line = Primary Flow", shape=plaintext];
        legend2 [label="Dashed Line = Fallback/Optional", shape=plaintext];
        legend3 [label="Cost Target: $1.70/village/month", shape=plaintext, fontcolor="#d32f2f"];
    }
}
